      "content": "import { CodeBlock } from \"@/registry/default/ui/code-block\";\r\n\r\nconst code = `// Wait for the animation...\r\nconsole.log(\"Hello!\");`;\r\n\r\nexport default function CodeBlockAnimationsDemo() {\r\n  return (\r\n    <div className=\"grid w-full max-w-3xl gap-8 md:grid-cols-2\">\r\n      <div className=\"space-y-2\">\r\n        <h3 className=\"font-medium text-muted-foreground text-sm\">Fade In</h3>\r\n        <CodeBlock\r\n          code={code}\r\n          language=\"typescript\"\r\n          animation=\"fadeIn\"\r\n          key=\"fade\"\r\n        />\r\n      </div>\r\n\r\n      <div className=\"space-y-2\">\r\n        <h3 className=\"font-medium text-muted-foreground text-sm\">Slide In</h3>\r\n        <CodeBlock\r\n          code={code}\r\n          language=\"typescript\"\r\n          animation=\"slideIn\"\r\n          key=\"slide\"\r\n        />\r\n      </div>\r\n\r\n      <div className=\"space-y-2\">\r\n        <h3 className=\"font-medium text-muted-foreground text-sm\">Highlight</h3>\r\n        <CodeBlock\r\n          code={code}\r\n          language=\"typescript\"\r\n          animation=\"highlight\"\r\n          key=\"highlight\"\r\n        />\r\n      </div>\r\n\r\n      <div className=\"space-y-2\">\r\n        <h3 className=\"font-medium text-muted-foreground text-sm\">\r\n          Typewriter\r\n        </h3>\r\n        <CodeBlock\r\n          code={code}\r\n          language=\"typescript\"\r\n          animation=\"typewriter\"\r\n          key=\"typewriter\"\r\n        />\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n",
