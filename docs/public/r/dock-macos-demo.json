      <Clock />\r\n          </DockIcon>\r\n          <DockLabel>Clock</DockLabel>\r\n        </DockItem>\r\n\r\n        <DockItem>\r\n          <DockIcon>\r\n            <Notebook />\r\n          </DockIcon>\r\n          <DockLabel>Notes</DockLabel>\r\n        </DockItem>\r\n\r\n        <DockItem>\r\n          <DockIcon>\r\n            <Terminal />\r\n          </DockIcon>\r\n          <DockLabel>Terminal</DockLabel>\r\n        </DockItem>\r\n\r\n        <DockItem>\r\n          <DockIcon>\r\n            <Settings />\r\n          </DockIcon>\r\n          <DockLabel>System Settings</DockLabel>\r\n        </DockItem>\r\n\r\n        <DockSeparator />\r\n\r\n        <DockItem>\r\n          <DockIcon>\r\n            <Camera />\r\n          </DockIcon>\r\n          <DockLabel>Camera</DockLabel>\r\n        </DockItem>\r\n\r\n        <DockItem>\r\n          <DockIcon className=\"text-red-500\">\r\n            <Trash2 />\r\n          </DockIcon>\r\n          <DockLabel>Trash</DockLabel>\r\n        </DockItem>\r\n      </Dock>\r\n    </div>\r\n  );\r\n}\r\n",
